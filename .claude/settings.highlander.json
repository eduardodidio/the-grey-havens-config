{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "HIGHLANDER MODE — activates Claude Code Auto Mode on startup so Waves run autonomously without permission prompts. Liberal allow-list is kept as a fallback for sessions where auto mode is unavailable. Use only in sandboxed projects without secrets. Copy this over settings.json to activate.",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(didio:*)",
      "Bash(didio-*)",
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(curl:*)",
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)"
    ]
  },
  "useAutoModeDuringPlan": true,
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${DIDIO_HOME:-$HOME/.claude-didio-config}/patterns/hooks/feature-end-digest/hook.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${DIDIO_HOME:-$HOME/.claude-didio-config}/bin/hooks/didio-pre-tool.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${DIDIO_HOME:-$HOME/.claude-didio-config}/bin/hooks/didio-post-tool.sh"
          }
        ]
      }
    ]
  },
  "_hooks_decision": "Highlander runs Waves autonomously with no human watching the budget, so the session-guard (Pre/Post) and learning digest (Stop) hooks are wired here too — same ${DIDIO_HOME} convention as templates/.claude/settings.json. Parity intentional, not an oversight."
}
