            CONTRACT["DRIVER_CONTRACT.md<br/>(security posture documented)"]
        end
        GIT[".gitignore<br/>(logs/, *.meta.json,<br/>*.checkpoint.json)"]
    end

    subgraph Tests["Test layer"]
        RUN["tests/run.sh<br/>(project test runner)"]
        SIM["tests/lib/sim-harness.sh<br/>(echo-driver simulation)"]
        F02T["F02 suites<br/>injection · meta · guardrails<br/>secrets · shellcheck · validate<br/>sim-dispatch · sim-parallel · spawn-meta"]
    end

    subgraph Global["Global install (~/.claude-didio-config) — read-only ref"]
        RW["didio run-wave<br/>(Wave parallelism, test gate,<br/>checkpoint/resume)"]
    end

    CONF --> CFG
    CFG --> SPAWN
    SPAWN --> DRVC
    SPAWN --> DRVX
